<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resume Download | Prasanna Kumar</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:linear-gradient(135deg,#0A66C2,#081b29);
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.card{
    background:white;
    width:380px;
    padding:40px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 10px 30px rgba(0,0,0,.3);
}

h1{
    color:#0A66C2;
    margin-bottom:15px;
}

p{
    color:#555;
    margin-bottom:25px;
    line-height:1.6;
}

button{
    background:#0A66C2;
    color:white;
    border:none;
    padding:14px 35px;
    font-size:17px;
    border-radius:8px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    background:#084b96;
    transform:translateY(-3px);
}

button:active{
    transform:scale(.97);
}
</style>

</head>
<body>

<div class="card">
    <h1>Prasanna Kumar T</h1>

    <p>
        Click the button below to download my latest resume.
    </p>

    <button onclick="downloadResume()">
        📄 Download Resume
    </button>
</div>

<script>

function downloadResume(){

    const permission = confirm(
        "Do you want to download Prasanna Kumar's Resume?"
    );

    if(permission){

        const link=document.createElement("a");

        link.href="Prasanna_Kumar_Resume.pdf";

        link.download="Prasanna_Kumar_Resume.pdf";

        document.body.appendChild(link);

        link.click();

        document.body.removeChild(link);

    }
    else{

        alert("Download Cancelled.");

    }

}

</script>

</body>
</html>
